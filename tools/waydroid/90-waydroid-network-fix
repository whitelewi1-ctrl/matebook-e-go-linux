#!/usr/bin/env bash
# SPDX-License-Identifier: GPL-2.0-or-later
# NetworkManager dispatcher script for Waydroid LXC bridge
#
# This script automatically adds the default gateway (192.168.240.1)
# when the waydroid0 bridge interface comes up.
#
# This eliminates the need for:
# - Hardcoded 15-second sleep in waydroid-net-fix.service
# - Manual waydroid shell command
# - Duplicate route errors on bridge addition
#
# Installation as root:
#   cp tools/waydroid/90-waydroid-network-fix /etc/NetworkManager/dispatcher.d/
#   chmod +x /etc/NetworkManager/dispatcher.d/90-waydroid-network-fix
#
# Note: NetworkManager must be configured to manage the waydroid0 interface.
# Add the following to /etc/NetworkManager/conf.d/waydroid.conf:
#   [keyfile]
#   unmanaged-devices=except:interface-name:waydroid0
#
# Copyright (c) 2026 Lewis White

INTERFACE="waydroid0"
GATEWAY="192.168.240.1"

case "$2" in
    up)
        # Wait for waydroid container network to be ready
        sleep 2

        logger -t "waydroid-network-fix" "Waiting for waydroid container network"

        # Poll until waydroid shell is responsive (max 30 seconds)
        for i in $(seq 1 15); do
            if waydroid shell -- ip route show 2>/dev/null | grep -q "192.168.240"; then
                # Network is up inside container, check if default route exists
                if ! waydroid shell -- ip route show 2>/dev/null | grep -q "^default"; then
                    logger -t "waydroid-network-fix" "Adding default route in waydroid container"
                    waydroid shell -- ip route add default via "$GATEWAY" 2>&1 | logger -t "waydroid-network-fix"

                    if waydroid shell -- ip route show 2>/dev/null | grep -q "^default"; then
                        logger -t "waydroid-network-fix" "Successfully added default route in container"
                    else
                        logger -t "waydroid-network-fix" "Failed to add default route in container"
                    fi
                else
                    logger -t "waydroid-network-fix" "Default route already exists in container"
                fi
                exit 0
            fi
            sleep 2
        done

        logger -t "waydroid-network-fix" "Timeout waiting for waydroid container network"
        exit 1
        ;;

    down)
        # Remove default route in container when bridge goes down
        logger -t "waydroid-network-fix" "Removing default route in waydroid container"
        waydroid shell -- ip route del default 2>/dev/null || true
        ;;

    *)
        logger -t "waydroid-network-fix" "Unknown action: $2, ignoring"
        ;;
esac
