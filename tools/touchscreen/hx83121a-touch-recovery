#!/usr/bin/env python3
"""
HX83121A Touch Recovery Service
Checks if touchscreen firmware is loaded, if not triggers Boot ROM via GPIO reset.
Deploy: /usr/local/bin/hx83121a-touch-recovery
"""
import subprocess, struct, time, mmap, os, sys

TLMM_BASE = 0x0F100000
I2C_BUS = 4
AHB_ADDR = 0x48
HID_ADDR = "4-004f"
MAX_RETRIES = 3

def log(msg):
    print(f"hx83121a: {msg}", flush=True)

def mmio_rw(addr, val=None):
    page = addr & ~0xFFF
    off = addr & 0xFFF
    fd = os.open("/dev/mem", os.O_RDWR | os.O_SYNC)
    m = mmap.mmap(fd, 0x1000, mmap.MAP_SHARED, mmap.PROT_READ | mmap.PROT_WRITE, offset=page)
    if val is not None:
        m[off:off+4] = struct.pack("<I", val)
    r = struct.unpack("<I", m[off:off+4])[0]
    m.close()
    os.close(fd)
    return r

def i2c_write(data):
    cmd = ["i2ctransfer", "-y", str(I2C_BUS), f"w{len(data)}@0x{AHB_ADDR:02x}"]
    cmd += [f"0x{b:02x}" for b in data]
    return subprocess.run(cmd, capture_output=True, text=True).returncode == 0

def i2c_read(cb, n):
    cmd = ["i2ctransfer", "-y", str(I2C_BUS), f"w1@0x{AHB_ADDR:02x}", f"0x{cb:02x}", f"r{n}"]
    r = subprocess.run(cmd, capture_output=True, text=True)
    if r.returncode != 0:
        return None
    return [int(x, 16) for x in r.stdout.strip().split()]

def ahb_read32(addr):
    i2c_write([0x00] + list(struct.pack("<I", addr)))
    i2c_write([0x0C, 0x00])
    v = i2c_read(0x08, 4)
    return struct.unpack("<I", bytes(v))[0] if v else None

def get_status():
    return ahb_read32(0x900000A8)

def check_touch_input():
    """Check if touch HID device exists in input subsystem."""
    r = subprocess.run(["grep", "-c", "4858:121A", "/proc/bus/input/devices"],
                       capture_output=True, text=True)
    return int(r.stdout.strip()) > 0 if r.returncode == 0 else False

def unbind_hid():
    subprocess.run(["bash", "-c", f"echo {HID_ADDR} > /sys/bus/i2c/drivers/i2c_hid_of/unbind 2>/dev/null"])
    time.sleep(0.3)

def bind_hid():
    subprocess.run(["bash", "-c", f"echo {HID_ADDR} > /sys/bus/i2c/drivers/i2c_hid_of/bind 2>/dev/null"])

def gpio_reset_boot_rom():
    """UEFI-style GPIO sequence: GPIO174 HIGH -> GPIO99 reset -> wait Boot ROM -> GPIO174 LOW"""
    gpio174_cfg_addr = TLMM_BASE + 174 * 0x1000
    gpio174_io_addr = gpio174_cfg_addr + 4
    gpio99_cfg_addr = TLMM_BASE + 99 * 0x1000
    gpio99_io_addr = gpio99_cfg_addr + 4

    # Save original config
    cfg174_orig = mmio_rw(gpio174_cfg_addr)
    cfg99_orig = mmio_rw(gpio99_cfg_addr)

    # GPIO 174 HIGH (I2C mode select)
    mmio_rw(gpio174_cfg_addr, cfg174_orig | (1 << 9))  # OE
    mmio_rw(gpio174_io_addr, 0x02)  # HIGH
    time.sleep(0.01)

    # GPIO 99 reset pulse
    mmio_rw(gpio99_cfg_addr, cfg99_orig | (1 << 9))  # OE
    mmio_rw(gpio99_io_addr, 0x00)  # LOW (assert reset)
    time.sleep(0.05)  # 50ms pulse
    mmio_rw(gpio99_io_addr, 0x02)  # HIGH (release reset)
    mmio_rw(gpio99_cfg_addr, cfg99_orig & ~(1 << 9))  # restore input

    # Wait for Boot ROM (up to 5 seconds)
    for i in range(50):
        time.sleep(0.1)
        status = get_status()
        if status == 0x05:
            elapsed = (i + 1) * 0.1
            log(f"Boot ROM loaded firmware in {elapsed:.1f}s")
            # GPIO 174 LOW (SPI mode)
            mmio_rw(gpio174_io_addr, 0x00)
            mmio_rw(gpio174_cfg_addr, cfg174_orig)
            return True

    # Timeout - restore GPIO 174
    mmio_rw(gpio174_io_addr, 0x00)
    mmio_rw(gpio174_cfg_addr, cfg174_orig)
    return False

def main():
    # Check if I2C device exists
    if not os.path.exists(f"/sys/bus/i2c/devices/{HID_ADDR}"):
        log("I2C device not found, skipping")
        return 0

    # Wait briefly for i2c_hid_of to probe
    for _ in range(10):
        if check_touch_input():
            log("Touchscreen already working")
            return 0
        time.sleep(0.5)

    log("Touchscreen not detected after 5s, checking IC status...")

    # Unbind HID to access AHB bridge
    unbind_hid()

    status = get_status()
    if status is None:
        log("IC not responding on I2C, cannot recover")
        bind_hid()
        return 1

    log(f"IC status: 0x{status:02X}")

    if status == 0x05:
        log("Firmware running but no HID device, rebinding...")
        bind_hid()
        time.sleep(2)
        if check_touch_input():
            log("Touch restored by rebind")
            return 0
        log("Rebind didn't help")
        return 1

    # Status != 0x05, try Boot ROM recovery
    for attempt in range(1, MAX_RETRIES + 1):
        log(f"Recovery attempt {attempt}/{MAX_RETRIES}: GPIO reset + Boot ROM...")

        if gpio_reset_boot_rom():
            # Boot ROM succeeded, rebind HID
            bind_hid()
            time.sleep(2)
            if check_touch_input():
                log(f"Touch recovered on attempt {attempt}!")
                return 0
            else:
                log("Boot ROM OK but HID not detected, retrying...")
                unbind_hid()
        else:
            log(f"Boot ROM failed on attempt {attempt}")

    log(f"Recovery failed after {MAX_RETRIES} attempts")
    bind_hid()  # rebind anyway
    return 1

if __name__ == "__main__":
    sys.exit(main())
